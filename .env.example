# metainflow-studio-cli 环境变量配置模版
# 复制为 .env 并填入实际值：cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────────

# OpenAI 兼容接口地址（默认指向 OpenAI 官方）
PROVIDER_BASE_URL=https://api.openai.com/v1

# API 密钥（必填）
PROVIDER_API_KEY=sk-...

# 单次请求超时秒数
PROVIDER_TIMEOUT_SECONDS=60

# 失败后最大重试次数
PROVIDER_MAX_RETRIES=2

# ── 模型选择 ──────────────────────────────────────────────────────────────────

# parse-doc 命令使用的模型
PROVIDER_MODEL_DOC_PARSE=gpt-4.1-mini

# search-summary 命令使用的模型
PROVIDER_MODEL_WEB_SEARCH=gpt-4.1-mini

# web-crawl 命令使用的模型
PROVIDER_MODEL_WEB_FETCH=gpt-4.1-mini

# ── 测试开关 ──────────────────────────────────────────────────────────────────

# 设为 1 时启用真实样本矩阵集成测试（默认跳过）
# METAINFLOW_RUN_SAMPLE_MATRIX=1

# ── Web Fetch ────────────────────────────────────────────────────────────────

# web-crawl 抓取是否校验 SSL（默认开启，设为 0 可跳过校验）
METAINFLOW_WEB_FETCH_VERIFY_SSL=1
